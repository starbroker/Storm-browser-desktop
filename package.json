{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "build": {
    "appId": "com.stormbrowser.app",
    "productName": "Storm Browser",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "msix"
      ],
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "shortcutName": "Storm Browser",
      "runAfterFinish": true
    },
    "appx": {
      "identityName": "com.stormbrowser.app",
      "publisher": "CN=StormBrowser",
      "publisherDisplayName": "Storm Browser",
      "displayName": "Storm Browser"
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:build": "node generate-assets.js && vite build && electron-builder",
    "electron:build:win": "node generate-assets.js && vite build && electron-builder --win",
    "electron:build:mac": "node generate-assets.js && vite build && electron-builder --mac",
    "electron:build:linux": "node generate-assets.js && vite build && electron-builder --linux"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dompurify": "^3.4.11",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "author": {
    "name": "Himank",
    "email": "himankcpro@gmail.com"
  },
  "description": "Storm Browser",
  "homepage": "https://github.com/himank/storm-browser"
}
