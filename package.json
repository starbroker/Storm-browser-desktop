{
  "name": "storm-browser",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "build": {
    "appId": "com.stormxbrowser.app",
    "productName": "StormX Browser",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "msix",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "certificateFile": null,
      "certificatePassword": null,
      "msix": {
        "identityName": "StormXBrowser",
        "publisher": "CN=StormXBrowser",
        "publisherDisplayName": "StormX Browser",
        "displayName": "StormX Browser",
        "languages": [
          "en-US"
        ],
        "backgroundColor": "#1a1a2e"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StormX Browser",
      "uninstallDisplayName": "StormX Browser",
      "installerIcon": "assets/installer-icon.ico",
      "uninstallerIcon": "assets/uninstaller-icon.ico",
      "installerHeader": "assets/installer-header.bmp",
      "installerSidebar": "assets/installer-sidebar.bmp"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "extendInfo": {
        "NSPrincipalClass": "NSApplication"
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "icon": "assets/icon.icns",
      "title": "StormX Browser"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network;Utility",
      "icon": "assets/icon.png"
    },
    "deb": {
      "depends": [
        "gconf2",
        "gconf-service",
        "libappindicator1",
        "libnotify4",
        "libxtst6",
        "libnss3"
      ],
      "afterInstall": "./scripts/postinstall.sh",
      "afterRemove": "./scripts/postremove.sh"
    },
    "appImage": {
      "artifactName": "StormX-Browser-${version}.${ext}"
    }
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "build:win-exe": "vite build && electron-builder --win nsis",
    "build:win-appx": "vite build && electron-builder --win msix",
    "build:mac": "vite build && electron-builder --mac dmg",
    "build:linux": "vite build && electron-builder --linux deb AppImage"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dompurify": "^3.4.11",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "rcedit": "^5.0.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.10"
  },
  "author": {
    "name": "Himank",
    "email": "himankcpro@gmail.com"
  },
  "description": "Storm Browser - ColorOS 16 Inspired Desktop Browser",
  "homepage": "https://github.com/starbroker/Storm-browser-desktop"
}
